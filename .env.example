# Environment Variables Template
# Copy this file to .env.local and fill in your Firebase credentials

# Firebase Configuration
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Firebase Cloud Messaging
VITE_FCM_VAPID_KEY=your-vapid-key

# LiveKit Server
VITE_LIVEKIT_URL=https://lk.earnon.ai/
VITE_FUNCTIONS_REGION=us-central1
# Optional explicit HTTP fallback endpoint for token generation
# VITE_LIVEKIT_TOKEN_HTTP_URL=https://us-central1-your-project.cloudfunctions.net/generateLiveKitTokenHttp

# LiveKit Function Runtime (set in Tink/functions/.env for local functions)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_URL=lk.earnon.ai
LIVEKIT_ROOM=default-room

# Call Provider: livekit | jitsi
VITE_CALL_PROVIDER=livekit

# Jitsi Domain (used when VITE_CALL_PROVIDER=jitsi)
VITE_JITSI_DOMAIN=meet.jit.si

# Development
VITE_USE_FIREBASE_EMULATOR=false
